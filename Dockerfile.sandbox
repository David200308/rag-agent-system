FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# bash, grep, sed, find, awk are already in the ubuntu base image.
# Install only packages that are not pre-installed.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl wget git \
    python3 python3-pip \
    nodejs npm \
    jq zip unzip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash sandbox
RUN mkdir -p /workspace && chown sandbox:sandbox /workspace

USER sandbox
WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]
