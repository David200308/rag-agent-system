.idea/
.vscode/
.metals/
.bsp/
.claude/
.DS_Store
Thumbs.db

# ── Java / Maven ──────────────────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
.mvn/wrapper/maven-wrapper.jar

# ── Spring Boot ───────────────────────────────────────────────────────────────
application-local.yml
application-secret*.yml
application.local.yml
application.prod.yml

# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules/
frontend/.pnpm-store/
frontend/.pnpm-debug.log
pnpm-debug.log

# ── Next.js ───────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/next-env.d.ts

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
!frontend/.env.local.example
.env.prod

# ── Docker secrets directory ──────────────────────────────────────────────────
# secrets/* contains plaintext credentials for docker-compose.prod.yml.
# Never commit these. The directory itself is tracked via secrets/.gitkeep.
secrets/*
!secrets/.gitkeep

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
