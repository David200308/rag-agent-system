# Spring Boot backend URL (used by Next.js rewrites in next.config.ts)
BACKEND_URL=http://localhost:8081

# Exposed to the browser (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_NAME="RAG Agent"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to false to disable login entirely (open access, no redirect to /login).
# Must match the `auth.enabled` value in Spring Boot's application.yml.
# Default: true
AUTH_ENABLED=true

# JWT expiry in hours — must match `auth.jwt-expiry-hours` in application.yml.
# Used to set the maxAge of the rag-session cookie.
# Default: 24
AUTH_JWT_EXPIRY_HOURS=24
