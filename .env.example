# Copy this file to .env and fill in your values.
# docker-compose.yml reads .env automatically — no extra flags needed.
#
#   cp .env.example .env

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DB=ragagent
MYSQL_USER=ragagent
MYSQL_PASSWORD=ragagent

# ── LLM provider: openai | anthropic | openrouter | local ─────────────────────
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama / LM Studio running on the host (only used when LLM_PROVIDER=local)
LOCAL_LLM_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=gemma3
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# ── Auth (set AUTH_ENABLED=true to require email + OTP login) ─────────────────
AUTH_ENABLED=false
# Generate a strong secret: openssl rand -base64 64
AUTH_JWT_SECRET=changeme-use-a-long-random-base64-string-in-production
AUTH_JWT_EXPIRY_HOURS=24
AUTH_OTP_EXPIRY_MINUTES=10

# ── Resend (only needed when AUTH_ENABLED=true) ───────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# ── Weaviate (leave blank for anonymous access) ───────────────────────────────
WEAVIATE_API_KEY=
